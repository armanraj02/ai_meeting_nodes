APP_ENV=dev
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./agentic_meeting_ai.db

# RAG / Vector store
CHROMA_PERSIST_DIR=./data/embeddings/chroma
RAG_COLLECTION=meeting_ai

# LLM (optional). If not set, system uses a deterministic local fallback model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Workflow integrations (optional)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=

